{
  "name": "@decklee/design-book",
  "version": "0.1.0",
  "description": "Static Astro showcase of the @decklee/design-system — a navigable DeckLee deck that documents its own primitives, tokens, themes, and the LLM-never-CSS rule.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "test": "vitest run",
    "predev": "tsx src/scripts/generate-prop-tables.ts && tsx src/scripts/generate-token-data.ts",
    "prebuild": "tsx src/scripts/generate-prop-tables.ts && tsx src/scripts/generate-token-data.ts",
    "generate-prop-tables": "tsx src/scripts/generate-prop-tables.ts",
    "generate-token-data": "tsx src/scripts/generate-token-data.ts"
  },
  "dependencies": {
    "@decklee/design-system": "workspace:*",
    "@decklee/schema": "workspace:*",
    "@decklee/viewer": "workspace:*",
    "astro": "^6.4.8",
    "reveal.js": "^6.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
