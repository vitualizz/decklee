---
import "@decklee/design-system/tokens";
import "@decklee/design-system/themes/dev";
import SectionRail from "./SectionRail.astro";
import type { NavGroup, NavLeaf, PlayFixture } from "../data/play.js";

/**
 * BookShell — the persistent two-column document shell for every design-book
 * page (Home, /foundations/[topic], /themes, /rule, /component/[name]).
 *
 * Purely structural: it renders NO <h1> (R4 / OI-DC-001 Option A) — title is
 * used only for <title> + <meta description>. Every slotted page owns its own
 * <h1>. The sidebar is single-source: ONE <nav aria-label="Design Book"> inside
 * ONE <aside>, wrapped in a <details> drawer. On desktop CSS forces the drawer
 * visible (display:contents) and hides the summary; on mobile it is a native
 * <details> toggle. No new JS, no islands (TR-9).
 */
interface Props {
  title: string;
  description?: string;
  currentHref: string;
}

const { title, description, currentHref } = Astro.props;

// Verbatim from LandingLayout — the only fonts the design system references.
const GOOGLE_FONTS_HREF =
  "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap";

// ── NavGroup builder (TR-1): the fixtures glob lives ONLY here. obs-2633: all
// typed partition logic stays in frontmatter; the template reads resolved arrays.
const rawFixtures = import.meta.glob("/src/data/fixtures/**/*.demo.ts", {
  eager: true,
}) as Record<string, { default: PlayFixture }>;

const FIXTURE_ORDER = ["hero", "two-up", "code", "quote"];
const orderIndex = (name: string) => {
  const i = FIXTURE_ORDER.indexOf(name);
  return i === -1 ? FIXTURE_ORDER.length : i;
};

const LOCKED: NavLeaf[] = Object.values(rawFixtures)
  .map((m) => m.default)
  .filter((f) => f.tier === "locked")
  .sort((a, b) => orderIndex(a.name) - orderIndex(b.name))
  .map((f) => ({ label: f.title, href: `/component/${f.name}` }));

const DRAFT: NavLeaf[] = Object.values(rawFixtures)
  .map((m) => m.default)
  .filter((f) => f.tier === "draft")
  .sort((a, b) => orderIndex(a.name) - orderIndex(b.name))
  .map((f) => ({ label: f.title, href: `/component/${f.name}` }));

// Display order: Overview → Foundations → Primitives → Themes → Rule → Drafts,
// with the set-apart 'See it live →' external leaf last.
const groups: NavGroup[] = [
  { label: "Overview", href: "/", children: [] },
  {
    label: "Foundations",
    children: [
      { label: "Color", href: "/foundations/color" },
      { label: "Typography", href: "/foundations/typography" },
      { label: "Spacing", href: "/foundations/spacing" },
    ],
  },
  { label: "Primitives", children: LOCKED },
  { label: "Themes", href: "/themes", children: [] },
  { label: "The Rule", href: "/rule", children: [] },
  { label: "Drafts", children: DRAFT },
  { label: "See it live →", href: "/demo", external: true, children: [] },
];
---

<!doctype html>
<html lang="en" data-theme="dev">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={GOOGLE_FONTS_HREF} />
  </head>
  <body>
    <a class="dk-skip sr-only" href="#main-content">Skip to content</a>

    {/*
      Single-source sidebar: the <details> + <main> are BOTH children of the grid.
      The <details> is `open` (so its aside content is always rendered — Chrome
      hides a closed <details>'s content via content-visibility, which CSS cannot
      reliably override). On desktop the details is display:contents (so the aside
      becomes the grid's first column) and the summary is hidden; on mobile the
      native <details open> toggle applies (summary is the hamburger). Exactly one
      <nav aria-label="Design Book"> in the DOM.
    */}
    <div class="dk-book__grid">
      <details class="dk-book__drawer" open>
        <summary class="dk-book__drawer-toggle" aria-label="Open navigation menu">
          <span aria-hidden="true">&#9776;</span>
        </summary>
        <aside aria-label="Book navigation">
          {/* If adding a second <nav> on this page, give it a distinct aria-label. */}
          <nav aria-label="Design Book">
            <SectionRail navMode="tree" groups={groups} currentHref={currentHref} />
          </nav>
        </aside>
      </details>

      <main id="main-content"><slot /></main>
    </div>

    <style is:global>
      :root {
        color-scheme: dark;
        --dk-book-sidebar-w: 260px;
        --dk-book-content-max: 1100px;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        background-color: var(--dk-color-bg-base);
        color: var(--dk-color-fg-primary);
        font-family: var(--dk-type-family-body);
      }

      /* MOVED verbatim from LandingLayout (R3) — LandingSection on the book
         content pages depends on this measure. */
      .dk-landing__col {
        max-width: 1100px;
        margin-inline: auto;
        padding-inline: var(--dk-space-8);
      }

      .dk-skip {
        position: absolute;
        left: -9999px;
      }

      .dk-skip:focus {
        position: fixed;
        top: var(--dk-space-3);
        left: var(--dk-space-3);
        width: auto;
        height: auto;
        clip: auto;
        z-index: 100;
        padding: var(--dk-space-3) var(--dk-space-4);
        background: var(--dk-color-bg-surface);
        color: var(--dk-color-fg-primary);
        outline: 2px solid var(--dk-color-accent-1);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Reduced motion: instant scroll (NFR-02). */
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      /* Desktop: persistent sidebar + content grid. */
      @media (min-width: 1024px) {
        .dk-book__drawer {
          display: contents;
        }
        .dk-book__drawer-toggle {
          display: none;
        }
        .dk-book__grid {
          display: grid;
          grid-template-columns: var(--dk-book-sidebar-w) 1fr;
          min-height: 100vh;
        }
        aside[aria-label="Book navigation"] {
          position: sticky;
          top: 0;
          height: 100vh;
          overflow-y: auto;
          border-right: 1px solid var(--dk-color-border);
          background: var(--dk-color-bg-base);
        }
        main#main-content {
          max-width: var(--dk-book-content-max);
          margin-inline: auto;
          padding-inline: var(--dk-space-8);
          width: 100%;
          box-sizing: border-box;
        }
      }

      /* Mobile: collapsed drawer + visible hamburger toggle. */
      @media (max-width: 1023px) {
        .dk-book__grid {
          display: block;
        }
        main#main-content {
          padding-inline: var(--dk-space-8);
        }
        .dk-book__drawer-toggle {
          display: flex;
          align-items: center;
          justify-content: center;
          min-width: 44px;
          min-height: 44px;
          cursor: pointer;
          list-style: none;
        }
        .dk-book__drawer-toggle::-webkit-details-marker {
          display: none;
        }
      }
    </style>
  </body>
</html>
