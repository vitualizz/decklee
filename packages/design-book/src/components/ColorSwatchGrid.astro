---
import type { ColorSwatch } from "../scripts/generate-token-data.js";

interface Props {
  swatches: ColorSwatch[];
}

const { swatches } = Astro.props;
---

<ul class="dk-swatches" role="list">
  {swatches.map((sw) => (
    <li class="dk-swatch">
      <figure class="dk-swatch__fig">
        {/* The swatch square is the ONE sanctioned inline-style exception (book-chrome). */}
        <div class="dk-swatch__chip" style={`background:${sw.rgb};`} aria-hidden="true"></div>
        <figcaption class="dk-swatch__cap">
          <code class="dk-swatch__token">{sw.token}</code>
          <span class="dk-swatch__role">{sw.role}</span>
          <span class="dk-swatch__contrast">
            {sw.contrastRatio === null
              ? "alpha-blended — N/A"
              : `${sw.contrastRatio}:1 ${sw.label}`}
          </span>
          {sw.derivedFrom && (
            <span class="dk-swatch__alias">alias → {sw.derivedFrom}</span>
          )}
        </figcaption>
      </figure>
    </li>
  ))}
</ul>

<style>
  .dk-swatches {
    list-style: none;
    margin: 0;
    padding: var(--dk-space-4);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--dk-space-4);
  }

  .dk-swatch {
    margin: 0;
  }

  .dk-swatch__fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--dk-space-2);
  }

  .dk-swatch__chip {
    /* 64px = --dk-space-12 (48) + --dk-space-4 (16); no new design-system token. */
    width: calc(var(--dk-space-12) + var(--dk-space-4));
    height: calc(var(--dk-space-12) + var(--dk-space-4));
    border: 1px solid var(--dk-color-border);
    border-radius: var(--dk-space-2);
  }

  .dk-swatch__cap {
    display: flex;
    flex-direction: column;
    gap: var(--dk-space-1);
    font-family: var(--dk-type-family-code);
    font-size: var(--dk-type-scale-caption);
  }

  .dk-swatch__token {
    color: var(--dk-color-fg-primary);
    letter-spacing: var(--dk-type-ls-eyebrow);
  }

  .dk-swatch__role,
  .dk-swatch__contrast,
  .dk-swatch__alias {
    color: var(--dk-color-fg-muted);
    font-family: var(--dk-type-family-body);
  }
</style>
