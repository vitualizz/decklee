---
import "@decklee/design-system/tokens";
import "@decklee/design-system/themes/dev";
import SectionRail from "./SectionRail.astro";
import type { LandingNavItem } from "../data/design-book.js";

/**
 * LandingLayout — the scroll-document shell for the design book landing page.
 *
 * A full `<!doctype html>` document with ZERO reveal.js imports, so none of the
 * reveal CSS or the deck's is:global styles enter the landing bundle. Landmarks:
 * one <header>, one <nav>, one <main id="main-content">, one <footer>. The skip
 * link is the first focusable element. Smooth scroll is gated behind
 * prefers-reduced-motion.
 */
interface Props {
  title: string;
  description?: string;
  navItems: LandingNavItem[];
}

const { title, description, navItems } = Astro.props;

// Verbatim from BookLayout — the only fonts the design system references.
const GOOGLE_FONTS_HREF =
  "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap";
---

<!doctype html>
<html lang="en" data-theme="dev">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={GOOGLE_FONTS_HREF} />
  </head>
  <body>
    <a class="dk-skip sr-only" href="#main-content">Skip to main content</a>

    <header class="dk-landing__header">
      <div class="dk-landing__col">
        <h1 class="dk-landing__title">{title}</h1>
        {description && <p class="dk-landing__lede">{description}</p>}
      </div>
      <nav class="dk-landing__nav" aria-label="Design Book sections">
        <SectionRail navMode="anchor" items={navItems} />
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="dk-landing__footer">
      <slot name="footer" />
    </footer>

    <style is:global>
      :root {
        color-scheme: dark;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        background-color: var(--dk-color-bg-base);
        color: var(--dk-color-fg-primary);
        font-family: var(--dk-type-family-body);
      }

      .dk-landing__col {
        max-width: 1100px;
        margin-inline: auto;
        padding-inline: var(--dk-space-8);
      }

      .dk-landing__header {
        border-bottom: 1px solid var(--dk-color-border);
        padding-block: calc(var(--dk-space-slide-pad-y) + var(--dk-space-8));
      }

      .dk-landing__title {
        margin: 0;
        font-family: var(--dk-type-family-display);
        font-weight: var(--dk-type-weight-bold);
        line-height: var(--dk-type-lh-tight);
        letter-spacing: var(--dk-type-ls-display);
        color: var(--dk-color-fg-primary);
        /* Fluid, NOT the literal --dk-type-scale-hero (108px) token. */
        font-size: clamp(40px, 6vw, 96px);
      }

      .dk-landing__lede {
        margin: var(--dk-space-5) 0 0;
        max-width: 60ch;
        font-family: var(--dk-type-family-body);
        color: var(--dk-color-fg-secondary);
      }

      .dk-landing__nav {
        margin-top: var(--dk-space-6);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .dk-skip:focus {
        position: fixed;
        top: var(--dk-space-3);
        left: var(--dk-space-3);
        width: auto;
        height: auto;
        clip: auto;
        z-index: 100;
        padding: var(--dk-space-3) var(--dk-space-4);
        background: var(--dk-color-bg-surface);
        color: var(--dk-color-fg-primary);
        outline: 2px solid var(--dk-color-accent-1);
      }

      /* Reduced motion: instant scroll (NFR-02). */
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </body>
</html>
