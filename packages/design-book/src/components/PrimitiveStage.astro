---
/**
 * PrimitiveStage — a bounded 16:9 card that hosts a design-system primitive
 * (or a fixed-px book-chrome viz) at its native 1920×1080 canvas, scaled down
 * to fit the card width via `transform: scale(--stage-scale)`.
 *
 * The inner wrapper is `aria-hidden="true"` so the hosted primitive's own
 * h1/h2/h3 never pollute the outer page heading outline (WCAG 1.3.1); the
 * outer card carries `aria-label` as the accessible name for the region.
 *
 * The 1920/1080 literals are the scale-mechanism constants (the deck canvas
 * dimensions), NOT theme-able values — the only literal px allowed here.
 */
interface Props {
  label: string;
  aspectRatio?: string;
}

const { label, aspectRatio = "16 / 9" } = Astro.props;
---

<div class="dk-stage" data-stage aria-label={label} style={`aspect-ratio:${aspectRatio};`}>
  <div class="dk-stage__inner" aria-hidden="true">
    <slot />
  </div>
</div>

<script is:inline>
  document.querySelectorAll("[data-stage]").forEach((el) => {
    const set = () =>
      el.style.setProperty("--stage-scale", (el.clientWidth / 1920).toFixed(6));
    if ("ResizeObserver" in window) {
      new ResizeObserver(set).observe(el);
    }
    set();
  });
</script>

<style>
  .dk-stage {
    position: relative;
    overflow: hidden;
    width: 100%;
    border: 1px solid var(--dk-color-border);
    background: var(--dk-color-bg-base);
  }

  .dk-stage__inner {
    position: absolute;
    top: 0;
    left: 0;
    /* 1920×1080 = the DeckLee deck canvas. Scale-mechanism constants, not
       theme-able — the only literal px permitted in landing chrome. */
    width: 1920px;
    height: 1080px;
    transform: scale(var(--stage-scale, 1));
    transform-origin: top left;
  }
</style>
