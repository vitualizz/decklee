---
import DemoShell from "../components/DemoShell.astro";
import Hero from "@decklee/design-system/primitives/Hero.astro";
import TwoUp from "@decklee/design-system/primitives/TwoUp.astro";
import Code from "@decklee/design-system/primitives/Code.astro";
import Quote from "@decklee/design-system/primitives/Quote.astro";
import { DEMO_SLIDES } from "../data/demo-deck.js";
import type { DemoSlide } from "../data/demo-deck.js";

// Astro template parser mis-reads generics in {} expressions (obs-2633).
// All typed logic stays in frontmatter; template uses `as any`.
const PRIMITIVE_MAP: Record<DemoSlide["layout"], unknown> = {
  "hero": Hero,
  "two-up": TwoUp,
  "code": Code,
  "quote": Quote,
};

const slides: DemoSlide[] = DEMO_SLIDES;
---

<DemoShell title="Lumen — Observability that explains itself" theme="aurora">
  {slides.map((slide) => {
    const Comp = PRIMITIVE_MAP[slide.layout] as any;
    return (
      <section data-id={slide.id} aria-label={slide.label}>
        <div class="dk-demo-slide">
          <Comp {...slide.props as any} />
        </div>
      </section>
    );
  })}
</DemoShell>
