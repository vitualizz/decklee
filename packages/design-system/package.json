{
  "name": "@decklee/design-system",
  "version": "0.1.0",
  "description": "Token CSS layer, stateless Astro layout primitives, dev theme, and code-highlight + theme-resolver utilities for DeckLee.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.astro"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": "./src/tokens/index.css",
    "./tokens/color": "./src/tokens/color.css",
    "./tokens/typography": "./src/tokens/typography.css",
    "./tokens/spacing": "./src/tokens/spacing.css",
    "./tokens/syntax": "./src/tokens/syntax.css",
    "./themes/dev": "./src/themes/dev/dev.css",
    "./themes/aurora": "./src/themes/aurora/aurora.css",
    "./primitives/*": "./src/primitives/*"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/themes",
    "src/primitives"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit && astro check",
    "test": "vitest run"
  },
  "dependencies": {
    "@decklee/schema": "workspace:*",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "astro": "^6.4.8",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
