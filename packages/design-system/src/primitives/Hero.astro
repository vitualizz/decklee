---
import type { HeroProps } from "@decklee/schema";
import "./hero.css";

type Props = HeroProps & { theme_id: string };

const {
  headline,
  subheadline,
  eyebrow,
  background_treatment = "color",
  image_src,
  image_alt,
  cta_label,
  theme_id,
} = Astro.props;

// theme_id is part of the primitive contract handshake but is not rendered:
// the viewer sets [data-theme] on the deck root. Void-reference to keep the
// interface honest without an unused-var lint.
void theme_id;

const showBackgroundImage = background_treatment === "image" && Boolean(image_src);
---

<div class="dk-hero" data-layout="hero">
  {eyebrow && <p class="dk-hero__eyebrow">{eyebrow}</p>}
  <h1 class="dk-hero__headline">{headline}</h1>
  {subheadline && <p class="dk-hero__subheadline">{subheadline}</p>}
  {cta_label && <p class="dk-hero__cta">{cta_label}</p>}
  {showBackgroundImage && (
    <img class="dk-hero__bg" src={image_src} alt={image_alt ?? ""} />
  )}
</div>
