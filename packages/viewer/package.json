{
  "name": "@decklee/viewer",
  "version": "0.1.0",
  "description": "Framework-free client-side runtime: DOM twin of the design-system primitives, deck-island boot, and reveal.js wiring for DeckLee.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reveal-config": {
      "types": "./dist/reveal-config.d.ts",
      "development": "./src/reveal-config.ts",
      "import": "./dist/reveal-config.js"
    }
  },
  "files": [
    "dist",
    "vendor/reveal/manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size-report": "node --experimental-strip-types scripts/size-report.ts"
  },
  "dependencies": {
    "@decklee/schema": "workspace:*",
    "@decklee/design-system": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^25.0.0",
    "reveal.js": "^6.0.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
